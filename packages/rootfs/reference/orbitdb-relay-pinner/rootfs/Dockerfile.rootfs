FROM --platform=linux/amd64 debian:12

ENV DEBIAN_FRONTEND=noninteractive
ENV LIBGUESTFS_BACKEND=direct

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    jq \
    libguestfs-tools \
    linux-image-amd64 \
    python3 \
    qemu-system-x86 \
    qemu-utils \
    tar \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/relay-deployer-pwa

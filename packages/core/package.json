{
  "name": "@le-space/core",
  "version": "0.3.0",
  "description": "Reusable Aleph deployment, runtime, and guest lifecycle logic.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "@le-space/aleph-bootstrap": "workspace:*",
    "@le-space/shared-types": "workspace:*"
  },
  "scripts": {
    "build": "node --check ./src/index.ts && node --check ./src/manifests.ts && node --check ./src/crns.ts && node --check ./src/bootstrap-registration.ts",
    "build:publish": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.publish.json",
    "test": "node --test ./test/**/*.test.ts",
    "lint": "echo \"core lint placeholder\""
  }
}
